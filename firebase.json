{
  "firestore": {
    "rules": "firestore.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "runtime": "nodejs22"
    }
  ],
  "hosting": {
    "public": ".",
    "headers": [
      {
        "source": "/service-worker.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/assets/healthpath-brand-logo.png",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "/manifest.webmanifest",
        "headers": [
          {
            "key": "Content-Type",
            "value": "application/manifest+json"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/create-checkout-session",
        "function": {
          "functionId": "createCheckoutSession",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/create-billing-portal-session",
        "function": {
          "functionId": "createBillingPortalSession",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/stripe-webhook",
        "function": {
          "functionId": "stripeWebhook",
          "region": "us-central1"
        }
      },
      {
        "source": "/",
        "destination": "/index.html"
      }
    ],
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "trailingSlash": false
  },
  "extensions": {
    "firestore-send-email": "firebase/firestore-send-email@0.2.9"
  }
}
